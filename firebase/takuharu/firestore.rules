rules_version = '2';

// たくはるファイナンス Firestore Security Rules
//
// 設計方針:
//   - 許可された uid（allowedUsers）のみ全データにアクセス可能
//     （= 指定の2人＋検証用 だけが使える）
//   - データ共有は households の members（世帯コードで参加）で行う
//   - users/{uid} … 本人のみ / households/** … メンバーのみ
//   - その他は全拒否（デフォルト deny）
//
// アカウントを追加/削除したい場合は allowedUsers の uid を編集すること。

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // 許可された uid 一覧（この人たちだけアクセス可能）
    function allowedUsers() {
      return [
        'yfTtT5N1DTNPgtm7PXM2l1mTkY92',  // fffuttta@gmail.com
        'TdIx6DB8PpVdPH7wo3QhavmP1ia2',  // noel.31128@gmail.com
        'vnoNjaHvhvew2HYhfSY7DlqLyC72'   // takuharumika@gmail.com (検証用)
      ];
    }

    function isAllowed() {
      return isSignedIn() && request.auth.uid in allowedUsers();
    }

    // 自分のユーザードキュメント
    match /users/{uid} {
      allow read, write: if isAllowed() && request.auth.uid == uid;
    }

    // 世帯ドキュメント
    match /households/{hid} {
      function isMember() {
        return isSignedIn()
            && resource.data.members is list
            && request.auth.uid in resource.data.members;
      }
      allow create: if isAllowed()
          && request.resource.data.members is list
          && request.auth.uid in request.resource.data.members;
      // join 時の存在確認のため、許可ユーザーなら get は許可。
      allow get: if isAllowed();
      allow list: if isAllowed() && isMember();
      allow update: if isAllowed()
          && (isMember()
              || request.auth.uid in request.resource.data.members);
      allow delete: if isAllowed() && isMember();

      // 世帯配下の取引
      match /transactions/{txId} {
        function parentMembers() {
          return get(/databases/$(database)/documents/households/$(hid)).data.members;
        }
        allow read, write: if isAllowed()
            && request.auth.uid in parentMembers();
      }

      // 世帯配下のプランニング項目（やりたいこと/行きたい場所/お店）
      match /plan_items/{itemId} {
        function parentMembers() {
          return get(/databases/$(database)/documents/households/$(hid)).data.members;
        }
        allow read, write: if isAllowed()
            && request.auth.uid in parentMembers();
      }
    }
  }
}
