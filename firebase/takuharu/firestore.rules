rules_version = '2';

// たくはるファイナンス Firestore Security Rules
//
// 設計方針:
//   - users/{uid} … 本人のみ read/write（自分の householdId を保持）
//   - households/{hid} … メンバー（members 配列に uid が含まれる）のみ read/write
//   - households/{hid}/transactions/** … 同じくメンバーのみ read/write
//   - 世帯への参加は、コードを知っている認証済みユーザーが members に自分を追加できる
//   - その他は全拒否（デフォルト deny）

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // 自分のユーザードキュメント
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // 世帯ドキュメント
    match /households/{hid} {
      // 既存メンバーは読み書き可
      function isMember() {
        return isSignedIn()
            && resource.data.members is list
            && request.auth.uid in resource.data.members;
      }
      // 新規作成: 作成者本人が members に含まれていること
      allow create: if isSignedIn()
          && request.resource.data.members is list
          && request.auth.uid in request.resource.data.members;
      // 読み取り: メンバーのみ。ただし未参加でもコードで参加できるよう
      //          認証済みなら get は許可（join 時の存在確認用）。
      allow get: if isSignedIn();
      allow list: if isMember();
      // 更新: 既存メンバー、または「自分を members に追加するだけ」の参加操作
      allow update: if isMember()
          || (isSignedIn()
              && request.auth.uid in request.resource.data.members);
      allow delete: if isMember();

      // 世帯配下の取引
      match /transactions/{txId} {
        function parentMembers() {
          return get(/databases/$(database)/documents/households/$(hid)).data.members;
        }
        allow read, write: if isSignedIn()
            && request.auth.uid in parentMembers();
      }

      // 世帯配下のプランニング項目（やりたいこと/行きたい場所/お店）
      match /plan_items/{itemId} {
        function parentMembers() {
          return get(/databases/$(database)/documents/households/$(hid)).data.members;
        }
        allow read, write: if isSignedIn()
            && request.auth.uid in parentMembers();
      }
    }
  }
}
