{
    "name":  "futafinance_desktop",
    "productName":  "FutaFinance",
    "version":  "1.0.542",
    "description":  "FutaFinance desktop shell (Electron wrapper around the Flutter web build).",
    "main":  "main.js",
    "author":  "RunStrategy",
    "license":  "UNLICENSED",
    "private":  true,
    "scripts":  {
                    "start":  "electron .",
                    "build":  "electron-builder --win nsis --publish never",
                    "dist":  "electron-builder --win nsis --publish always"
                },
    "dependencies":  {
                         "electron-updater":  "^6.8.9"
                     },
    "devDependencies":  {
                            "electron":  "^32.0.0",
                            "electron-builder":  "^25.1.8"
                        },
    "build":  {
                  "appId":  "jp.runstrategy.futafinance.desktop",
                  "productName":  "FutaFinance",
                  "directories":  {
                                      "output":  "dist"
                                  },
                  "files":  [
                                "main.js",
                                "preload.js",
                                "build-info.json",
                                "assets/**/*",
                                "oauth.json",
                                "package.json"
                            ],
                  "extraResources":  [
                                         {
                                             "from":  "web-dist",
                                             "to":  "web-dist"
                                         }
                                     ],
                  "win":  {
                              "target":  "nsis",
                              "icon":  "assets/icon.ico",
                              "artifactName":  "FutaFinance-setup.exe"
                          },
                  "nsis":  {
                               "oneClick":  true,
                               "perMachine":  false,
                               "deleteAppDataOnUninstall":  false,
                               "createDesktopShortcut":  true,
                               "createStartMenuShortcut":  true
                           },
                  "publish":  {
                                  "provider":  "github",
                                  "owner":  "fffuttta-design",
                                  "repo":  "futafinance-desktop-releases"
                              }
              }
}